{
  "name": "pogly-widget-editor",
  "displayName": "Pogly Widget Editor",
  "description": "Native VS Code preview and intellisense for Pogly Widgets",
  "version": "1.0.0",
  "publisher": "pogly",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:pogly.dashboard"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "pogly.dashboard",
        "displayName": "Pogly Dashboard",
        "selector": [
          {
            "filenamePattern": "*.widget.json"
          }
        ],
        "priority": "default"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.widget.json",
        "url": "./resources/widget-schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "npm run build",
    "watch": "esbuild src/extension/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "build": "esbuild src/extension/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}
