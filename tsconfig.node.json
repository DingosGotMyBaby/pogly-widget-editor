{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/main/**/*", "src/preload/**/*", "electron.vite.config.*"]
}
